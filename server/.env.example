# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# JWT RSA Keys
JWT_ACCESS_PRIVATE_KEY=your_rsa_private_key
JWT_ACCESS_PUBLIC_KEY=your_rsa_public_key
JWT_REFRESH_PRIVATE_KEY=your_refresh_rsa_private_key
JWT_REFRESH_PUBLIC_KEY=your_refresh_rsa_public_key

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# Resend
RESEND_API_KEY=your_resend_api_key

# Server
PORT=3000
NODE_ENV=development
